{
  "name": "sapi-lang",
  "displayName": "Sapi Language",
  "description": "Syntax highlighting for .sapi files",
  "version": "1.1.0",
  "publisher": "local",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "sapi",
        "aliases": ["Sapi", "sapi"],
        "extensions": [".sapi"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sapi",
        "scopeName": "source.sapi",
        "path": "./syntaxes/sapi.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sapi",
        "path": "./snippets/sapi.json"
      }
    ]
  }
}
