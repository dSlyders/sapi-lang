{
  "name": "Sapi",
  "scopeName": "source.sapi",
  "fileTypes": ["sapi"],
  "patterns": [
    { "include": "#doc-comment" },
    { "include": "#line-comment" },
    { "include": "#sql-string" },
    { "include": "#string" },
    { "include": "#return-status" },
    { "include": "#route-line" },
    { "include": "#fn-decl" },
    { "include": "#use-ref" },
    { "include": "#for-in-loop" },
    { "include": "#return-simple" },
    { "include": "#await-sql-decl" },
    { "include": "#decl-with-name" },
    { "include": "#request-meta-decl" },
    { "include": "#field-decl" },
    { "include": "#var-decl" },
    { "include": "#if-condition-bare-var" },
    { "include": "#condition-var-before-operator" },
    { "include": "#method-call" },
    { "include": "#object-kv-unified" },
    { "include": "#object-value-variable" },
    { "include": "#var-before-method" },
    { "include": "#operators" },
    { "include": "#assign-operator" },
    { "include": "#config-key" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#boolean" },
    { "include": "#numbers" },
    { "include": "#function-call" },
    { "include": "#brackets" }
  ],
  "repository": {
    "doc-comment": {
      "name": "comment.line.documentation.sapi",
      "match": "///.*$"
    },
    "line-comment": {
      "name": "comment.line.double-slash.sapi",
      "match": "//.*$"
    },
    "sql-string": {
      "contentName": "string.quoted.backtick.sql.sapi",
      "begin": "(`)",
      "end": "(`)",
      "beginCaptures": { "1": { "name": "punctuation.definition.string.backtick.sapi" } },
      "endCaptures":   { "1": { "name": "punctuation.definition.string.backtick.sapi" } },
      "patterns": [
        { "include": "#sql-parens" },
        { "include": "#sql-single-quote" },
        {
          "match": "(\\{)([^}]+)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.interpolation.begin.sql.sapi" },
            "2": { "name": "variable.template-expression.sql.sapi" },
            "3": { "name": "punctuation.definition.interpolation.end.sql.sapi" }
          }
        },
        {
          "name": "entity.name.function.sql.sapi",
          "match": "(?i)\\b(COALESCE|COUNT|SUM|AVG|MIN|MAX|LOWER|UPPER|TRIM|ROUND|ABS|NOW|DATE|DATE_TRUNC|CONCAT|SUBSTRING|LENGTH|CAST|COALESCE|IFNULL|NULLIF)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.other.sql.sapi",
          "match": "(?i)\\b(SELECT|FROM|WHERE|INSERT|INTO|VALUES|UPDATE|SET|DELETE|ORDER|BY|ASC|DESC|LIMIT|OFFSET|JOIN|LEFT|RIGHT|INNER|OUTER|ON|AS|AND|OR|NOT|NULL|IS|GROUP|HAVING|DISTINCT|CREATE|TABLE|IF|DROP|ALTER|INDEX|LIKE|IN|BETWEEN|EXISTS|CASE|WHEN|THEN|ELSE|END|PRIMARY|KEY|UNIQUE|REFERENCES|FOREIGN|CONSTRAINT|DEFAULT|RETURNING|AUTO_INCREMENT|VARCHAR|TIMESTAMP|CURRENT_TIMESTAMP|INT|BOOLEAN|TEXT|WITH)\\b"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\.)",
          "captures": {
            "1": { "name": "variable.other.sql-alias.sapi" },
            "2": { "name": "punctuation.accessor.sql.sapi" }
          }
        },
        {
          "name": "keyword.operator.sql.sapi",
          "match": "(<=|>=|<>|!=|=|<|>|\\+|\\-|\\*|/|\\.)"
        },
        {
          "name": "variable.other.sql-ident.sapi",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "constant.numeric.sapi",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "sql-parens": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": { "0": { "name": "punctuation.section.parens.sql.sapi" } },
      "endCaptures":   { "0": { "name": "punctuation.section.parens.sql.sapi" } },
      "patterns": [
        {
          "name": "entity.name.function.sql.sapi",
          "match": "(?i)\\b(COALESCE|COUNT|SUM|AVG|MIN|MAX|LOWER|UPPER|TRIM|ROUND|ABS|NOW|DATE|DATE_TRUNC|CONCAT|SUBSTRING|LENGTH|CAST|COALESCE|IFNULL|NULLIF)\\b(?=\\s*\\()"
        },
        {
          "name": "keyword.other.sql.sapi",
          "match": "(?i)\\b(SELECT|FROM|WHERE|INSERT|INTO|VALUES|UPDATE|SET|DELETE|ORDER|BY|ASC|DESC|LIMIT|OFFSET|JOIN|LEFT|RIGHT|INNER|OUTER|ON|AS|AND|OR|NOT|NULL|IS|GROUP|HAVING|DISTINCT|CREATE|TABLE|IF|DROP|ALTER|INDEX|LIKE|IN|BETWEEN|EXISTS|CASE|WHEN|THEN|ELSE|END|PRIMARY|KEY|UNIQUE|REFERENCES|FOREIGN|CONSTRAINT|DEFAULT|RETURNING|AUTO_INCREMENT|VARCHAR|TIMESTAMP|CURRENT_TIMESTAMP|INT|BOOLEAN|TEXT|WITH)\\b"
        },
        { "include": "#sql-single-quote" },
        {
          "match": "(\\{)([^}]+)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.interpolation.begin.sql.sapi" },
            "2": { "name": "variable.template-expression.sql.sapi" },
            "3": { "name": "punctuation.definition.interpolation.end.sql.sapi" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\.)",
          "captures": {
            "1": { "name": "variable.other.sql-alias.sapi" },
            "2": { "name": "punctuation.accessor.sql.sapi" }
          }
        },
        {
          "name": "keyword.operator.sql.sapi",
          "match": "(<=|>=|<>|!=|=|<|>|\\+|\\-|\\*|/|\\.)"
        },
        {
          "name": "variable.other.sql-ident.sapi",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "constant.numeric.sapi",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "sql-single-quote": {
      "contentName": "string.quoted.single.sql.sapi",
      "begin": "(')",
      "end": "(')",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.sql.sapi" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.sql.sapi" }
      }
    },
    "string": {
      "contentName": "string.quoted.double.sapi",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.sapi" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.sapi" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.sapi",
          "match": "\\\\[ntr\"\\\\]"
        },
        {
          "match": "(\\{)([^}\"]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.interpolation.begin.sapi" },
            "2": { "name": "variable.template-expression.sapi" },
            "3": { "name": "punctuation.definition.interpolation.end.sapi" }
          }
        }
      ]
    },
    "return-status": {
      "match": "\\b(return)\\b\\s+([0-9]{3})\\s*:",
      "captures": {
        "1": { "name": "keyword.control.sapi" },
        "2": { "name": "constant.numeric.http-status.sapi" }
      }
    },
    "route-line": {
      "begin": "^([A-Z][a-zA-Z0-9]*)\\s+(get|post|put|patch|delete)\\s+(\")",
      "end": "\"",
      "beginCaptures": {
        "1": { "name": "entity.name.sapi" },
        "2": { "name": "keyword.declaration.sapi" },
        "3": { "name": "punctuation.definition.string.begin.sapi" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.sapi" }
      },
      "contentName": "string.quoted.route.sapi",
      "patterns": [
        {
          "match": "(\\{)([^}\"]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.route-param.begin.sapi" },
            "2": { "name": "variable.parameter.route.sapi" },
            "3": { "name": "punctuation.definition.route-param.end.sapi" }
          }
        }
      ]
    },
    "fn-decl": {
      "match": "\\b(async\\s+fn|fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.sapi" },
        "2": { "name": "entity.name.sapi" }
      }
    },
    "use-ref": {
      "match": "\\b(use)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.declaration.sapi" },
        "2": { "name": "entity.name.sapi" }
      }
    },
    "for-in-loop": {
      "match": "\\b(for)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(in)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.sapi" },
        "2": { "name": "variable.other.control-flow.sapi" },
        "3": { "name": "keyword.control.sapi" },
        "4": { "name": "variable.other.control-flow.sapi" }
      }
    },
    "return-simple": {
      "match": "\\b(return)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*$|\\s*[,}])",
      "captures": {
        "1": { "name": "keyword.control.sapi" },
        "2": { "name": "variable.other.sapi" }
      }
    },
    "await-sql-decl": {
      "comment": "await PascalType varname = ... (SQL struct result)",
      "match": "\\b(await)\\s+([A-Z][a-zA-Z0-9]*)\\s+([a-z_][a-zA-Z0-9_]*)\\s*=",
      "captures": {
        "1": { "name": "keyword.control.sapi" },
        "2": { "name": "storage.type.sapi" },
        "3": { "name": "variable.other.declaration.sapi" }
      }
    },
    "decl-with-name": {
      "match": "\\b(service|database|auth|sql|guard|body|log)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.sapi" },
        "2": { "name": "entity.name.sapi" }
      }
    },
    "request-meta-decl": {
      "comment": "header/cookie typed variable declaration in routes",
      "match": "\\b(header|cookie)\\s+((?:list:[a-zA-Z]+|string|int|float|bool|date|time|json|number|uuid|object)(?:\\?)?)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
      "captures": {
        "1": { "name": "keyword.declaration.request-meta.sapi" },
        "2": { "name": "storage.type.sapi" },
        "3": { "name": "variable.other.declaration.sapi" }
      }
    },
    "field-decl": {
      "comment": "body field declarations",
      "match": "\\b(field)\\s+((?:list:[a-zA-Z]+|string|int|float|bool|date|time|json|number|uuid|object)(?:\\?)?)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.field.sapi" },
        "2": { "name": "storage.type.sapi" },
        "3": { "name": "variable.other.declaration.sapi" }
      }
    },
    "var-decl": {
      "match": "\\b((?:list:[a-zA-Z]+|string|int|float|bool|date|time|json|number|uuid|object)(?:\\?)?)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "storage.type.sapi" },
        "2": { "name": "variable.other.declaration.sapi" }
      }
    },
    "if-condition-bare-var": {
      "comment": "if hasE { ... }",
      "match": "\\b(if|else\\s+if)\\b\\s+((?!true\\b|false\\b)[a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\{)",
      "captures": {
        "1": { "name": "keyword.control.sapi" },
        "2": { "name": "variable.other.control-flow.sapi" }
      }
    },
    "condition-var-before-operator": {
      "comment": "else if count == 0 { ... }",
      "match": "\\b((?!true\\b|false\\b)[a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*(==|!=|<=|>=|<|>|&&|\\|\\|))",
      "captures": {
        "1": { "name": "variable.other.control-flow.sapi" }
      }
    },
    "object-kv-unified": {
      "patterns": [
        {
          "comment": "quoted key in JSON object: \"key\":",
          "match": "(\")(\\w[\\w\\-]*)(\")\\s*(:)",
          "captures": {
            "1": { "name": "punctuation.definition.string.begin.sapi" },
            "2": { "name": "entity.other.attribute-name.sapi" },
            "3": { "name": "punctuation.definition.string.end.sapi" },
            "4": { "name": "punctuation.separator.key-value.sapi" }
          }
        },
        {
          "comment": "bare key in object literal after { or ,",
          "match": "([\\{,]\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(\\s*)(:|=)",
          "captures": {
            "2": { "name": "entity.other.attribute-name.sapi" },
            "4": { "name": "punctuation.separator.key-value.sapi" }
          }
        }
      ]
    },
    "object-value-variable": {
      "comment": "variable value in object-like key/value expressions",
      "match": "(:|=)\\s*((?!true\\b|false\\b)[a-zA-Z_][a-zA-Z0-9_]*)\\b(?!\\s*\\()",
      "captures": {
        "1": { "name": "punctuation.separator.key-value.sapi" },
        "2": { "name": "variable.other.sapi" }
      }
    },
    "var-before-method": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=:[a-zA-Z_][a-zA-Z0-9_]*\\s*\\()",
      "captures": {
        "1": { "name": "variable.other.sapi" }
      }
    },
    "assign-operator": {
      "name": "punctuation.separator.key-value.sapi",
      "match": "="
    },
    "operators": {
      "name": "keyword.operator.sapi",
      "match": "(==|!=|<=|>=|<|>|&&|\\|\\|)"
    },
    "config-key": {
      "comment": "indented key: value inside database/service/auth blocks",
      "match": "^\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*:(?=\\s)",
      "captures": {
        "1": { "name": "entity.other.attribute-name.sapi" }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sapi",
          "match": "\\b(if|else|return|await|for|required|in)\\b"
        },
        {
          "name": "keyword.declaration.sapi",
          "match": "\\b(service|database|import|fn|async|lock|sql|use|route|new|guard|body|auth|header|cookie|field|claims|log)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.sapi",
          "match": "\\b(?:list:[a-zA-Z]+)(?:\\?)?"
        },
        {
          "name": "storage.type.sapi",
          "match": "\\b(?:string|int|float|bool|date|time|json|number|uuid|object)(?:\\?)?"
        }
      ]
    },
    "boolean": {
      "name": "constant.language.boolean.sapi",
      "match": "\\b(true|false)\\b"
    },
    "numbers": {
      "name": "constant.numeric.sapi",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "method-call": {
      "patterns": [
        {
          "name": "support.function.execute.sapi",
          "match": "\\.(one|many|run)\\(\\)"
        },
        {
          "match": "(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "punctuation.accessor.sapi" },
            "2": { "name": "entity.name.function.method.sapi" }
          }
        }
      ]
    },
    "function-call": {
      "name": "entity.name.function.sapi",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
    },
    "brackets": {
      "name": "punctuation.bracket.sapi",
      "match": "[{}\\[\\]]"
    }
  }
}
